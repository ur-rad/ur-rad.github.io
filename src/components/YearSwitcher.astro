---
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url";
import { externalSymposia } from "@/site.config";
import {
  type Edition,
  type PageKey,
  editionPath,
  getAllEditions,
} from "@/data/editions";

interface Props {
  /** The edition currently being viewed. */
  activeCode: string;
  /** Which page we're on, so the switcher links to the same page in each year. */
  pageKey?: PageKey | undefined;
}

const { activeCode, pageKey = "home" } = Astro.props;

const editions = await getAllEditions();
const active = editions.find((e) => e.data.code === activeCode);
const activeLabel = active ? active.data.year : "";

// Show whenever there's somewhere to switch to (another edition or an
// external past site).
const show = editions.length > 1 || externalSymposia.length > 0;

function targetHref(edition: Edition) {
  return url(editionPath(edition, pageKey));
}
---

{
  show && (
    <details class="year-switcher relative">
      <summary
        class="flex h-8 items-center gap-x-1 rounded-lg px-2 cursor-pointer list-none bg-color-100 hover:bg-accent-base/10 text-accent-base text-xs sm:text-sm font-medium whitespace-nowrap"
        aria-label="Switch conference year"
      >
        <Icon aria-hidden="true" class="h-4 w-4" focusable="false" name="hugeicons:calendar-03" />
        <span>{activeLabel}</span>
        <Icon
          aria-hidden="true"
          class="h-3 w-3 transition-transform"
          focusable="false"
          name="hugeicons:arrow-down-01"
        />
      </summary>
      <ul
        class="absolute right-0 z-50 mt-1 min-w-[12rem] overflow-hidden rounded-lg border border-color-300 bg-surface shadow-[0px_10px_25px_rgba(0,0,0,0.15)] py-1"
      >
        {editions.map((edition) => {
          const isActive = edition.data.code === activeCode;
          return (
            <li>
              <a
                href={targetHref(edition)}
                aria-current={isActive ? "true" : "false"}
                class="flex items-center justify-between gap-x-2 px-3 py-1.5 text-xs sm:text-sm hover:bg-accent-base/10 text-lighter aria-[current=true]:font-semibold aria-[current=true]:text-accent-two"
              >
                <span class="whitespace-nowrap">UR-RAD {edition.data.year}</span>
                {edition.data.status === "current" && (
                  <span class="text-[0.65rem] uppercase tracking-wide text-accent-two/70 whitespace-nowrap">
                    current
                  </span>
                )}
              </a>
            </li>
          );
        })}

        {externalSymposia.length > 0 && (
          <li aria-hidden="true">
            <div class="my-1 border-t border-color-300" />
          </li>
        )}
        {externalSymposia.map((ext) => (
          <li>
            <a
              href={ext.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between gap-x-2 px-3 py-1.5 text-xs sm:text-sm hover:bg-accent-base/10 text-lighter"
            >
              <span class="whitespace-nowrap inline-flex items-center gap-x-1.5">
                {ext.label}
                <svg
                  viewBox="0 0 24 24"
                  width="12"
                  height="12"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="opacity-70 shrink-0"
                  aria-hidden="true"
                >
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" y1="14" x2="21" y2="3" />
                </svg>
              </span>
              <span class="text-[0.65rem] uppercase tracking-wide text-lightest whitespace-nowrap">
                External
              </span>
            </a>
          </li>
        ))}
      </ul>
    </details>
  )
}

<script>
  // Close the dropdown when clicking outside or pressing Escape.
  const initYearSwitcher = () => {
    document.querySelectorAll<HTMLDetailsElement>("details.year-switcher").forEach((el) => {
      if ((el as any).__ysBound) return;
      (el as any).__ysBound = true;
      document.addEventListener("click", (e) => {
        if (el.open && !el.contains(e.target as Node)) el.open = false;
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") el.open = false;
      });
    });
  };
  initYearSwitcher();
  document.addEventListener("astro:page-load", initYearSwitcher);
</script>
