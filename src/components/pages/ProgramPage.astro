---
import Section from "@/components/Section.astro";
import ContactCard from "@/components/ContactCard.astro";
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url";
import { type Edition, getSchedule } from "@/data/editions";
import { getPapersByEdition } from "@/data/papers";

interface Props {
  edition: Edition;
}

const { edition } = Astro.props;
const d = edition.data;

const papers = await getPapersByEdition(d.code);
const paperMap = Object.fromEntries(papers.map((p) => [p.id, p]));

const scheduleEntry = await getSchedule(d.code);
const schedule = scheduleEntry?.data.days ?? [];

const venueLine = [d.venue?.name, d.venue?.city, d.venue?.country]
  .filter(Boolean)
  .join(", ");

const headingMonthMap: Record<string, string> = {
  january: "01",
  february: "02",
  march: "03",
  april: "04",
  may: "05",
  june: "06",
  july: "07",
  august: "08",
  september: "09",
  october: "10",
  november: "11",
  december: "12",
};

function headingToIsoDate(heading: string, year: number): string | null {
  const m = heading.match(
    /\b(January|February|March|April|May|June|July|August|September|October|November|December)\s+(\d{1,2})(?:st|nd|rd|th)?\b/i,
  );
  if (!m) return null;
  const monthPart = m[1];
  const dayPart = m[2];
  if (!monthPart || !dayPart) return null;
  const mm = headingMonthMap[monthPart.toLowerCase()];
  if (!mm) return null;
  const dd = String(Number.parseInt(dayPart, 10)).padStart(2, "0");
  return `${year}-${mm}-${dd}`;
}
---

<h1 class="title">Program</h1>

<Section id="event-details">
  <div class="max-w-4xl mx-auto">
    <div class="p-4 sm:p-6 bg-accent-base/5 rounded-lg">
      <h2 class="mt-0 mb-4 text-lg sm:text-xl">Event Details</h2>
      <div class="grid gap-4 grid-cols-1 md:grid-cols-2">
        <div>
          <p><strong>Date:</strong> {d.dates.display}</p>
          <p><strong>Location:</strong> {venueLine}</p>
        </div>
        <div>
          <p><strong>Event:</strong> AAAI Fall Symposium</p>
          <p><strong>Format:</strong> In-person</p>
        </div>
      </div>
    </div>
  </div>
</Section>

<Section
  id="symposium-format"
  title="Symposium Format"
  subtitle="The symposium will be made up of paper presentations, keynote talks, panels, and breakout discussions."
>
  <div class="max-w-4xl mx-auto">
    <div class="grid gap-4 sm:gap-6 grid-cols-1 md:grid-cols-2">
      <div class="p-3 sm:p-4 border border-color-300 rounded-lg">
        <h3 class="text-base sm:text-lg font-semibold mb-2">
          Paper Presentations
        </h3>
        <p class="text-xs sm:text-sm">
          Accepted papers will be presented during dedicated sessions, allowing
          authors to share their research and engage with the community.
        </p>
      </div>

      <div class="p-3 sm:p-4 border border-color-300 rounded-lg">
        <h3 class="text-base sm:text-lg font-semibold mb-2">Keynote Talks</h3>
        <p class="text-xs sm:text-sm">
          Distinguished speakers from academia and industry will present their
          insights on robot application development.
        </p>
      </div>

      <div class="p-3 sm:p-4 border border-color-300 rounded-lg">
        <h3 class="text-base sm:text-lg font-semibold mb-2">
          Panel Discussions
        </h3>
        <p class="text-xs sm:text-sm">
          Interactive panels will explore key challenges and opportunities in
          unifying representations for robotics.
        </p>
      </div>

      <div class="p-3 sm:p-4 border border-color-300 rounded-lg">
        <h3 class="text-base sm:text-lg font-semibold mb-2">
          Breakout Sessions
        </h3>
        <p class="text-xs sm:text-sm">
          Focused discussions on specific topics will encourage collaboration
          and networking among participants.
        </p>
      </div>
    </div>
  </div>
</Section>

<Section id="schedule" title="Schedule">
  <div class="max-w-4xl mx-auto">
    {
      schedule.length === 0 ? (
        <div class="max-w-none text-center italic">
          Detailed schedule will be published closer to the symposium date.
        </div>
      ) : (
        <div class="space-y-4 sm:space-y-6">
          {schedule.map((day) => {
            const summaryText = day.heading
              .replace(/^DAY/i, "Day")
              .replace(":", " — ");
            return (
              <details
                open
                data-date={headingToIsoDate(day.heading, d.year) ?? undefined}
                class="group rounded-lg border border-color-300 bg-accent-base/5 open:bg-accent-base/10 transition-colors"
              >
                <summary class="cursor-pointer list-none p-4 sm:p-5 flex items-center justify-between">
                  <div>
                    <h3 class="m-0 text-base sm:text-lg font-semibold">
                      {summaryText}
                    </h3>
                  </div>
                  <svg
                    class="w-5 h-5 text-accent-two transition-transform duration-200 group-open:rotate-180"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 011.08 1.04l-4.25 4.25a.75.75 0 01-1.06 0L5.21 8.27a.75.75 0 01.02-1.06z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </summary>
                <div class="divide-y divide-special-lighter">
                  {day.entries.map((entry) => (
                    <div class="grid grid-cols-1 sm:grid-cols-[7rem_1fr] gap-2 sm:gap-4 items-start p-3 sm:p-4">
                      <div class="font-semibold text-accent-base text-xs sm:text-sm">
                        {entry.time}
                      </div>
                      {entry.paperSession ? (
                        <div class="max-w-none">
                          <strong>{entry.paperSession.title}</strong>
                          <ul class="mt-2 space-y-3 text-sm sm:text-base">
                            {entry.paperSession.items.map((it) => {
                              const p = paperMap[it.slug];
                              if (!p) {
                                return (
                                  <li>
                                    <em>{it.slug}</em>
                                  </li>
                                );
                              }
                              const authorNames = (p.data.authors || [])
                                .map((a) => a.name)
                                .join(", ");
                              return (
                                <li>
                                  <em>
                                    <a
                                      href={url(`papers/${p.id}/`)}
                                      class="text-link no-underline hover:underline focus-visible:underline underline-offset-2"
                                    >
                                      {p.data.title}
                                    </a>
                                  </em>
                                  {p.data.award && (
                                    <span class="ml-2 inline-flex items-center rounded bg-accent-one/10 text-accent-one px-2 py-0.5 text-xs">
                                      <Icon
                                        aria-hidden="true"
                                        class="h-3.5 w-3.5 mr-1"
                                        focusable="false"
                                        name="solar:cup-bold"
                                      />
                                      {p.data.award}
                                    </span>
                                  )}{" "}
                                  – {authorNames}
                                </li>
                              );
                            })}
                          </ul>
                        </div>
                      ) : (
                        <div
                          class="max-w-none"
                          set:html={entry.content}
                        />
                      )}
                    </div>
                  ))}
                </div>
              </details>
            );
          })}
        </div>
      )
    }
    <script>
      const __initScheduleAccordions = () => {
        const root = document.getElementById("schedule");
        if (!root) return;
        const panels = Array.from(
          root.querySelectorAll("details[data-date]"),
        ) as HTMLDetailsElement[];
        if (!panels.length) return;

        const now = new Date();
        const yyyy = now.getFullYear();
        const mm = String(now.getMonth() + 1).padStart(2, "0");
        const dd = String(now.getDate()).padStart(2, "0");
        const todayIso = `${yyyy}-${mm}-${dd}`;

        const match = panels.find((p) => p.dataset.date === todayIso) || null;

        if (match) {
          panels.forEach((p) => {
            p.open = p === match;
          });
        } else {
          panels.forEach((p) => {
            p.open = true;
          });
        }
      };
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", __initScheduleAccordions);
      } else {
        __initScheduleAccordions();
      }
      document.addEventListener("astro:page-load", __initScheduleAccordions);
    </script>
  </div>
</Section>

<Section id="registration" title="Registration">
  <div class="max-w-4xl mx-auto">
    <div class="max-w-none">
      <p>
        Registration will be handled through the main {
          d.urls?.aaai ? (
            <a href={d.urls.aaai} class="citrus-link">
              AAAI Fall Symposium Series website
            </a>
          ) : (
            <span>AAAI Fall Symposium Series website</span>
          )
        }. Please check the AAAI website for registration dates and details.
      </p>

      <div class="mt-8">
        <ContactCard message="Questions about the program?" />
      </div>
    </div>
  </div>
</Section>
