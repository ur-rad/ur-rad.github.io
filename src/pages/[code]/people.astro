---
import PageLayout from "@/layouts/Base.astro";
import PeoplePage from "@/components/pages/PeoplePage.astro";
import { getPastEditions } from "@/data/editions";

export async function getStaticPaths() {
  const editions = await getPastEditions();
  return editions.map((edition) => ({
    params: { code: edition.data.code },
    props: { edition },
  }));
}

const { edition } = Astro.props;
const meta = {
  description: `People - ${edition.data.title} AAAI Fall Symposium on Unifying Representations for Robot Application Development`,
  title: `${edition.data.title} · People`,
};
---

<PageLayout meta={meta} edition={edition} pageKey="people">
  <PeoplePage edition={edition} />
</PageLayout>
