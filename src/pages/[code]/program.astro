---
import PageLayout from "@/layouts/Base.astro";
import ProgramPage from "@/components/pages/ProgramPage.astro";
import { getPastEditions } from "@/data/editions";

export async function getStaticPaths() {
  const editions = await getPastEditions();
  return editions.map((edition) => ({
    params: { code: edition.data.code },
    props: { edition },
  }));
}

const { edition } = Astro.props;
const meta = {
  description: `Program - ${edition.data.title} AAAI Fall Symposium on Unifying Representations for Robot Application Development`,
  title: `${edition.data.title} · Program`,
};
---

<PageLayout meta={meta} edition={edition} pageKey="program">
  <ProgramPage edition={edition} />
</PageLayout>
