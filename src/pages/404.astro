---
import PageLayout from "@/layouts/Base.astro";
import { url } from "@/utils/url";
import { editionBasePath, getAllEditions } from "@/data/editions";

const meta = {
	description: "Oops! It looks like this page is lost in space!",
	title: "Oops! You found a missing page!",
};

// Known edition home paths (current at root, past prefixed), longest first so
// the more specific prefix wins. Non-home page segments that resolve under one
// of these bases but don't exist (e.g. Partners for a year with no partners)
// redirect to that edition's home instead of showing this 404 — matches the
// switcher's fallback for someone landing via a stale link or bookmark.
const editions = await getAllEditions();
const editionHomes = editions
	.map((e) => url(editionBasePath(e)))
	.sort((a, b) => b.length - a.length);
const pageSegments = ["call-for-papers/", "people/", "partners/", "program/"];
---

<PageLayout meta={meta}>
	<h1 class="title mb-6">404 | Oops something went wrong</h1>
	<p class="mb-8">Please use the navigation to find your way back</p>
</PageLayout>

<script is:inline define:vars={{ editionHomes, pageSegments }}>
	(() => {
		const path = window.location.pathname;
		for (const home of editionHomes) {
			if (path === home || !path.startsWith(home)) continue;
			const rest = path.slice(home.length);
			if (pageSegments.includes(rest)) {
				window.location.replace(home);
				return;
			}
		}
	})();
</script>
