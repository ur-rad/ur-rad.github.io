---
import PageLayout from "@/layouts/Base.astro";
import ProgramPage from "@/components/pages/ProgramPage.astro";
import { getCurrentEdition } from "@/data/editions";

const edition = await getCurrentEdition();
const meta = {
  description: `Program - ${edition.data.title} AAAI Fall Symposium on Unifying Representations for Robot Application Development`,
  title: "Program",
};
---

<PageLayout meta={meta} edition={edition} pageKey="program">
  <ProgramPage edition={edition} />
</PageLayout>
