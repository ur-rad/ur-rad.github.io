---
import BaseHead from "@/components/BaseHead.astro";
import SkipLink from "@/components/SkipLink.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";
import type { Edition, PageKey } from "@/data/editions";
import { getCurrentEdition } from "@/data/editions";
import "../styles/global.css";

interface Props {
  meta: SiteMeta;
  edition?: Edition | undefined;
  pageKey?: PageKey | undefined;
}

const {
  meta: { articleDate, description = siteConfig.description, ogImage, title },
  edition,
  pageKey,
} = Astro.props;

// Pagefind filter so search can group results by conference year.
const pagefindYear = edition ? String(edition.data.year) : undefined;

// Brand/site name reflects the edition being viewed; pages without an edition
// (tags, papers list, 404) fall back to the current edition (matching the
// header wordmark) rather than the static config default.
const brandEdition = edition ?? (await getCurrentEdition());
const siteName = brandEdition.data.title;

// Default the social card to the edition's own OG image (paper pages pass
// their own ogImage; non-edition pages fall back to /site-og.png in BaseHead).
const resolvedOgImage =
  ogImage ?? (edition ? `/og-image/edition/${edition.data.code}.png` : undefined);
---

<html
  class="overflow-x-hidden grid scroll-pt-20 scroll-smooth font-sans text-text text-xl md:text-base antialiased"
  lang={siteConfig.lang}
>
  <head>
    <BaseHead
      articleDate={articleDate}
      description={description}
      ogImage={resolvedOgImage}
      title={title}
      siteName={siteName}
    />
  </head>
  <body class="relative m-auto min-h-screen w-full max-w-6xl grow bg-surface">
    <ThemeProvider />
    <SkipLink />

    <div class="relative flex min-h-screen w-full flex-col">
      <!-- Full-width header -->
      <Header edition={edition} pageKey={pageKey} />

      <div class="relative flex min-h-screen w-full flex-1">
        <!-- Main container for the page content -->
        <div id="container" class="relative m-auto max-w-4xl grow">
          <div
            class="m-auto grid min-h-screen grid-rows-[1fr_auto] px-4 md:px-8 pt-20"
          >
            <main
              id="main"
              class="relative flex-grow"
              data-pagefind-body
              data-pagefind-filter={pagefindYear ? `year:${pagefindYear}` : undefined}
              data-pagefind-meta={pagefindYear ? `year:${pagefindYear}` : undefined}
            >
              <slot />
            </main>
            <Footer />
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
