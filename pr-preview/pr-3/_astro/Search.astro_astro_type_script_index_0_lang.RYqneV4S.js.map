  interface PagefindResultData {
    url: string;
    excerpt: string;
    meta: Record<string, string> & { title?: string; year?: string };
  }

  class SiteSearch extends HTMLElement {
    private dialog: HTMLDialogElement;
    private dialogFrame: HTMLDivElement;
    private openBtn: HTMLButtonElement;
    private closeBtn: HTMLButtonElement;
    private input: HTMLInputElement;
    private resultsEl: HTMLElement;
    private activeYear: string | null;
    private pagefind: any = null;
    private pagefindReady: Promise<any> | null = null;
    private debounce = 0;

    constructor() {
      super();
      this.openBtn = this.querySelector<HTMLButtonElement>("button[data-open-modal]")!;
      this.closeBtn = this.querySelector<HTMLButtonElement>("button[data-close-modal]")!;
      this.dialog = this.querySelector("dialog")!;
      this.dialogFrame = this.querySelector(".dialog-frame")!;
      this.input = this.querySelector<HTMLInputElement>(".pf-input")!;
      this.resultsEl = this.querySelector<HTMLElement>(".pf-results")!;
      this.activeYear = this.dataset.activeYear ?? null;

      this.openBtn.addEventListener("click", this.openModal);
      this.openBtn.disabled = false;
      this.closeBtn?.addEventListener("click", this.closeModal);
      this.input.addEventListener("input", this.onInput);
      this.querySelector("form")?.addEventListener("submit", (e) => e.preventDefault());
    }

    connectedCallback() {
      window.addEventListener("keydown", this.onWindowKeydown);
    }
    disconnectedCallback() {
      window.removeEventListener("keydown", this.onWindowKeydown);
    }

    private async loadPagefind() {
      if (this.pagefind) return this.pagefind;
      if (!this.pagefindReady) {
        const base = (import.meta as any).env.BASE_URL.replace(/\/$/, "");
        const path = `${base}/pagefind/pagefind.js`;
        this.pagefindReady = import(/* @vite-ignore */ path)
          .then(async (pf) => {
            await pf.options?.({ baseUrl: (import.meta as any).env.BASE_URL });
            this.pagefind = pf;
            return pf;
          })
          .catch(() => null);
      }
      return this.pagefindReady;
    }

    private onInput = () => {
      window.clearTimeout(this.debounce);
      this.debounce = window.setTimeout(() => this.runSearch(this.input.value.trim()), 180);
    };

    private async runSearch(query: string) {
      if (!query) {
        this.resultsEl.innerHTML =
          '<p class="pf-message text-lighter">Type to search across all years.</p>';
        return;
      }

      const pf = await this.loadPagefind();
      if (!pf) {
        this.resultsEl.innerHTML =
          '<p class="pf-message text-lighter">Search is available in the production build.</p>';
        return;
      }

      const search = await pf.search(query);
      if (this.input.value.trim() !== query) return; // stale
      const data: PagefindResultData[] = await Promise.all(
        search.results.slice(0, 30).map((r: any) => r.data()),
      );
      this.render(data);
    }

    private render(items: PagefindResultData[]) {
      if (!items.length) {
        this.resultsEl.innerHTML =
          '<p class="pf-message text-lighter">No results found.</p>';
        return;
      }

      const selected: PagefindResultData[] = [];
      const others: PagefindResultData[] = [];
      for (const item of items) {
        if (this.activeYear && item.meta?.year === this.activeYear) selected.push(item);
        else others.push(item);
      }

      // Group "others" by year, most recent first; untagged pages last.
      const byYear = new Map<string, PagefindResultData[]>();
      for (const item of others) {
        const y = item.meta?.year || "other";
        if (!byYear.has(y)) byYear.set(y, []);
        byYear.get(y)!.push(item);
      }
      const otherYears = [...byYear.keys()].sort((a, b) => {
        const an = /^\d+$/.test(a);
        const bn = /^\d+$/.test(b);
        if (an && bn) return Number(b) - Number(a);
        if (an) return -1; // numeric years before "other"
        if (bn) return 1;
        return 0;
      });

      let html = "";
      if (selected.length) {
        const label = this.activeYear ? `UR-RAD ${this.activeYear}` : "Results";
        html += this.section(label, selected);
      }
      if (otherYears.length) {
        html += '<div class="pf-other mt-6 pt-4 border-t border-color-400/40">';
        html += '<p class="text-xs font-semibold uppercase tracking-wider text-lighter mb-2">Other Years</p>';
        for (const y of otherYears) {
          const label = /^\d+$/.test(y) ? `UR-RAD ${y}` : "Other";
          html += this.section(label, byYear.get(y)!, true);
        }
        html += "</div>";
      }
      this.resultsEl.innerHTML = html;
    }

    private section(label: string, items: PagefindResultData[], small = false) {
      const head = small
        ? `<p class="text-xs font-medium text-accent-two mt-3 mb-1">${label}</p>`
        : `<p class="text-sm font-semibold text-accent-two mb-2">${label}</p>`;
      const list = items
        .map(
          (it) => `
        <li class="mb-4">
          <a class="font-semibold text-base text-accent-base hover:underline" href="${it.url}">
            ${it.meta?.title ?? it.url}
          </a>
          <p class="text-sm mt-0 mb-0 line-clamp-2 text-[var(--color-foreground)]">${it.excerpt ?? ""}</p>
        </li>`,
        )
        .join("");
      return `<div class="mb-2">${head}<ul class="list-none p-0 m-0">${list}</ul></div>`;
    }

    closeModal = () => {
      if (this.dialog.open) {
        this.dialog.close();
        document.body.classList.remove("overflow-hidden");
        window.removeEventListener("click", this.onWindowClick);
      }
    };

    openModal = (event?: MouseEvent) => {
      this.dialog.showModal();
      document.body.classList.add("overflow-hidden");
      this.input.focus();
      event?.stopPropagation();
      window.addEventListener("click", this.onWindowClick);
      // Warm up the index.
      this.loadPagefind();
    };

    onWindowClick = (event: MouseEvent) => {
      const isLink = "href" in (event.target || {});
      if (
        isLink ||
        (document.body.contains(event.target as Node) &&
          !this.dialogFrame.contains(event.target as Node))
      )
        this.closeModal();
    };

    onWindowKeydown = (e: KeyboardEvent) => {
      if (e.key === "/" && !this.dialog.open) {
        this.openModal();
        e.preventDefault();
      } else if (e.key === "Escape" && this.dialog.open) {
        this.closeModal();
      }
    };
  }

  customElements.define("site-search", SiteSearch);


