            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "logo": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "video": {
                "type": "string"
              },
              "blurb": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "year",
        "status",
        "title",
        "dates"
      ],
      "additionalProperties": false
