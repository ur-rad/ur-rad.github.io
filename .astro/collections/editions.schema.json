          "type": "string",
          "enum": [
            "current",
            "past",
            "upcoming"
          ]
        },
        "title": {
          "type": "string"
        },
        "tagline": {
          "type": "string"
        },
        "fullName": {
          "type": "string"
        },
        "dates": {
          "type": "object",
          "properties": {
            "start": {
              "type": "string"
            },
            "end": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "start",
            "end",
            "display"
          ],
          "additionalProperties": false
        },
        "venue": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "city": {
              "type": "string"
            },
            "country": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        },
        "urls": {
          "type": "object",
          "properties": {
            "registration": {
              "type": "string"
            },
            "submission": {
              "type": "string"
